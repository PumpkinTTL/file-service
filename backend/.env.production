NODE_ENV=production
PORT=3000

UPLOAD_BASE_DIR=/srv/uploads

DATABASE_PATH=/srv/file-service.db

BASE_URL=https://files.your-domain.com

JWT_SECRET=replace-with-production-secret
JWT_EXPIRES_IN=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

MAX_FILE_SIZE=52428800

ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,pdf,doc,docx,xls,xlsx,zip,rar,mp4,mp3
